<Window x:Class="GIFcut.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:behaviors="clr-namespace:GIFcut.Behaviors"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:GIFcut"
        mc:Ignorable="d"
        Title="GIF裁剪工具" Height="700" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}"
        AllowDrop="True"
        DataContext="{Binding}">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="DragEnter">
            <i:InvokeCommandAction Command="{Binding DragEnterCommand}" PassEventArgsToCommand="True"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="Drop">
            <i:InvokeCommandAction Command="{Binding DropCommand}" PassEventArgsToCommand="True"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <materialDesign:Card Grid.Row="0" Margin="10,5" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="打开" Command="{Binding OpenCommand}" Margin="0,0,10,0" Foreground="Black" FontWeight="Bold"/>
                <Button Content="{Binding PlayButtonText}" Command="{Binding PlayCommand}" IsEnabled="{Binding CanPlay}" Margin="0,0,5,0" Foreground="Black" FontWeight="Bold"/>
                <Button Content="停止" Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}" Margin="0,0,15,0" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text="{Binding FrameInfo}" VerticalAlignment="Center" Margin="10,0" Foreground="Black" FontWeight="Bold"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <TextBlock Text="裁剪区域:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="Black" FontWeight="Bold"/>
                <TextBox Width="60" Text="{Binding CropX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0"/>
                <TextBox Width="60" Text="{Binding CropY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0"/>
                <TextBox Width="60" Text="{Binding CropWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0"/>
                <TextBox Width="60" Text="{Binding CropHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,15,0"/>
                <TextBlock Text="速度:" VerticalAlignment="Center" Margin="5,0,5,0" Foreground="Black"/>
                <ComboBox Width="60" SelectedIndex="1" Margin="0,0,10,0" SelectionChanged="SpeedComboBox_SelectionChanged">
                    <ComboBoxItem Content="0.5x"/>
                    <ComboBoxItem Content="1x"/>
                    <ComboBoxItem Content="1.5x"/>
                    <ComboBoxItem Content="2x"/>
                    <ComboBoxItem Content="3x"/>
                </ComboBox>
                <Button Content="导出" Command="{Binding ExportCommand}" IsEnabled="{Binding CanExport}"
                        Background="#4CAF50" BorderBrush="#4CAF50" Foreground="Black" FontWeight="Bold"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- 预览区域 - 左右并排 3:1 -->
        <materialDesign:Card Grid.Row="1" Margin="10,5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：原图 + 裁剪框 -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="原图" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="Black"/>
                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <Grid>
                            <!-- GIF预览 + 边框 -->
                            <Border BorderBrush="RoyalBlue" BorderThickness="2">
                                <Image Source="{Binding CurrentFrameBitmap}" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- 裁剪框 -->
                            <Canvas x:Name="cropCanvas" Width="{Binding ImageWidth}" Height="{Binding ImageHeight}"
                                    Background="Transparent">
                                <i:Interaction.Behaviors>
                                    <behaviors:MouseEventBehavior
                                        LeftButtonDownCommand="{Binding CropMouseDownCommand}"
                                        MouseMoveCommand="{Binding CropMouseMoveCommand}"
                                        LeftButtonUpCommand="{Binding CropMouseUpCommand}"/>
                                </i:Interaction.Behaviors>

                                <!-- 裁剪框边框 -->
                                <Rectangle Stroke="Red" StrokeThickness="2" Fill="Transparent" Cursor="SizeAll"
                                           Width="{Binding CropWidth}" Height="{Binding CropHeight}"
                                           Canvas.Left="{Binding CropX}" Canvas.Top="{Binding CropY}"/>
                                <!-- 裁剪区域填充 -->
                                <Rectangle Fill="Transparent"
                                           Width="{Binding CropWidth}" Height="{Binding CropHeight}"
                                           Canvas.Left="{Binding CropX}" Canvas.Top="{Binding CropY}"/>



                                <!-- 4个边调整手柄 -->
                                <Border Width="{Binding HandleWidth}" Height="12" Background="Transparent" Cursor="SizeNS"
                                        Canvas.Left="{Binding HandleNLeft}" Canvas.Top="{Binding HandleNTop}"/>
                                <Border Width="{Binding HandleWidth}" Height="12" Background="Transparent" Cursor="SizeNS"
                                        Canvas.Left="{Binding HandleSLeft}" Canvas.Top="{Binding HandleSTop}"/>
                                <Border Width="12" Height="{Binding HandleHeight}" Background="Transparent" Cursor="SizeWE"
                                        Canvas.Left="{Binding HandleWLeft}" Canvas.Top="{Binding HandleWTop}"/>
                                <Border Width="12" Height="{Binding HandleHeight}" Background="Transparent" Cursor="SizeWE"
                                        Canvas.Left="{Binding HandleELeft}" Canvas.Top="{Binding HandleETop}"/>


                                <!-- 4个角调整手柄 -->
                                <Rectangle Width="25" Height="25" Fill="Transparent" Cursor="SizeNWSE"
                                        Canvas.Left="{Binding HandleNWLeft}" Canvas.Top="{Binding HandleNWTop}"/>
                                <Rectangle Width="25" Height="25" Fill="Transparent" Cursor="SizeNESW"
                                        Canvas.Left="{Binding HandleNELeft}" Canvas.Top="{Binding HandleNETop}"/>
                                <Rectangle Width="25" Height="25" Fill="Transparent" Cursor="SizeNESW"
                                        Canvas.Left="{Binding HandleSWLeft}" Canvas.Top="{Binding HandleSWTop}"/>
                                <Rectangle Width="25" Height="25" Fill="Transparent" Cursor="SizeNWSE"
                                        Canvas.Left="{Binding HandleSELeft}" Canvas.Top="{Binding HandleSETop}"/>
                            </Canvas>
                        </Grid>
                    </Viewbox>
                </Grid>

                <!-- 分隔线 -->
                <Rectangle Grid.Column="1" Width="2" Fill="#E0E0E0" Margin="10,20"/>

                <!-- 右侧：裁剪预览 -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="裁剪预览" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="Black"/>
                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <Image Source="{Binding CropPreviewBitmap}" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Viewbox>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- 时间轴区域 -->
        <materialDesign:Card Grid.Row="2" Margin="10,5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 帧范围选择 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="起始帧:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Black" FontWeight="Bold"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="{Binding SliderMax}" Value="{Binding StartFrame}" IsEnabled="{Binding CanSelectFrame}"/>
                    <TextBlock Grid.Column="2" Text="{Binding StartFrame}" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>

                    <TextBlock Grid.Column="3" Text="结束帧:" VerticalAlignment="Center" Margin="20,0,10,0" Foreground="Black" FontWeight="Bold"/>
                    <Slider Grid.Column="4" Minimum="0" Maximum="{Binding SliderMax}" Value="{Binding EndFrame}" IsEnabled="{Binding CanSelectFrame}"/>
                    <TextBlock Grid.Column="5" Text="{Binding EndFrame}" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                </Grid>

                <!-- 帧缩略图 -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                    <ItemsControl ItemsSource="{Binding Thumbnails}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding}" Width="50" Height="50" Stretch="Uniform" Margin="2"
                                       MouseLeftButtonDown="Thumbnail_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
