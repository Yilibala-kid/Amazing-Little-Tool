<UserControl x:Class="GIFcut.Controls.CropOverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Canvas x:Name="PART_Canvas" Background="Transparent">
        <!-- 遮罩层 (暗色区域) -->
        <Rectangle x:Name="PART_Overlay" Canvas.Left="0" Canvas.Top="0"
                   Fill="#80000000" IsHitTestVisible="False"/>

        <!-- 裁剪框 -->
        <Border x:Name="PART_CropBorder"
                BorderBrush="#00FF00"
                BorderThickness="2"
                Background="Transparent"
                Cursor="SizeAll">
        </Border>

        <!-- 左上角 -->
        <Rectangle x:Name="PART_ResizeNW" Width="12" Height="12"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeNWSE" Canvas.Left="0" Canvas.Top="0"/>

        <!-- 右上角 -->
        <Rectangle x:Name="PART_ResizeNE" Width="12" Height="12"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeNESW" Canvas.Left="0" Canvas.Top="0"/>

        <!-- 左下角 -->
        <Rectangle x:Name="PART_ResizeSW" Width="12" Height="12"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeNESW" Canvas.Left="0" Canvas.Top="0"/>

        <!-- 右下角 -->
        <Rectangle x:Name="PART_ResizeSE" Width="12" Height="12"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeNWSE" Canvas.Left="0" Canvas.Top="0"/>

        <!-- 上边 -->
        <Rectangle x:Name="PART_ResizeN" Width="30" Height="8"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeNS" Canvas.Left="0" Canvas.Top="0"/>

        <!-- 下边 -->
        <Rectangle x:Name="PART_ResizeS" Width="30" Height="8"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeNS" Canvas.Left="0" Canvas.Top="0"/>

        <!-- 左边 -->
        <Rectangle x:Name="PART_ResizeW" Width="8" Height="30"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeWE" Canvas.Left="0" Canvas.Top="0"/>

        <!-- 右边 -->
        <Rectangle x:Name="PART_ResizeE" Width="8" Height="30"
                  Fill="#00FF00" Stroke="White" StrokeThickness="1"
                  Cursor="SizeWE" Canvas.Left="0" Canvas.Top="0"/>
    </Canvas>
</UserControl>
